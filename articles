#!/usr/bin/env bash
# articles — fetch web articles and browse them in the terminal
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
# Resolve symlink to real script location
[ -L "$0" ] && SCRIPT_DIR="$(cd "$(dirname "$(readlink "$0")")" && pwd -P)"
ARTICLES_DIR="${ARTICLES_DIR:-$SCRIPT_DIR/history}"
PROMPTS_DIR="${PROMPTS_DIR:-$SCRIPT_DIR/prompts}"
mkdir -p "$ARTICLES_DIR" "$PROMPTS_DIR"

missing_commands() {
    local cmd
    for cmd in "$@"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            printf '%s\n' "$cmd"
        fi
    done
}

require_commands() {
    local missing=()
    local line
    local missing_count=0
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            missing+=("$line")
            missing_count=$((missing_count + 1))
        fi
    done < <(missing_commands "$@")

    if [ "$missing_count" -gt 0 ]; then
        echo "Missing dependencies: ${missing[*]}" >&2
        echo "Install them and try again." >&2
        return 1
    fi
}

brew_install() {
    local formulae=("$@")
    [ $# -eq 0 ] && return 0

    if ! command -v brew >/dev/null 2>&1; then
        echo "Homebrew is required to install: ${formulae[*]}" >&2
        echo "Install Homebrew from https://brew.sh and rerun articles." >&2
        return 1
    fi

    echo "Installing with Homebrew: ${formulae[*]}"
    brew install "${formulae[@]}"
}

ensure_pipx() {
    if command -v pipx >/dev/null 2>&1; then
        return 0
    fi

    brew_install pipx
}

pipx_bin_dir() {
    if command -v brew >/dev/null 2>&1; then
        brew --prefix bin
    else
        echo "$HOME/.local/bin"
    fi
}

pipx_install_app() {
    local package="$1"
    local app="$2"
    local bin_dir
    bin_dir="$(pipx_bin_dir)"

    echo "Installing $package with pipx..."
    PIPX_BIN_DIR="$bin_dir" pipx install "$package"
    hash -r

    if ! command -v "$app" >/dev/null 2>&1; then
        echo "Installed $package, but $app is still not on PATH." >&2
        echo "Expected binary directory: $bin_dir" >&2
        return 1
    fi
}

install_dependencies() {
    local missing=()
    local brew_formulae=()
    local missing_count=0
    local brew_count=0
    local need_pipx=0
    local dep
    while IFS= read -r dep; do
        if [ -n "$dep" ]; then
            missing+=("$dep")
            missing_count=$((missing_count + 1))
        fi
    done < <(missing_commands "$@")

    [ "$missing_count" -gt 0 ] || return 0

    for dep in "${missing[@]}"; do
        case "$dep" in
            gum|glow|fzf|crush)
                brew_formulae+=("$dep")
                brew_count=$((brew_count + 1))
                ;;
            trafilatura)
                need_pipx=1
                ;;
            *)
                echo "Don't know how to auto-install dependency: $dep" >&2
                return 1
                ;;
        esac
    done

    if [ "$brew_count" -gt 0 ]; then
        brew_install "${brew_formulae[@]}"
    fi

    if [ "$need_pipx" -eq 1 ]; then
        ensure_pipx
        if ! command -v trafilatura >/dev/null 2>&1; then
            pipx_install_app trafilatura trafilatura
        fi
    fi

    require_commands "$@"
}

# --- Preset prompts (create defaults if dir is empty) ---
init_prompts() {
    [ -n "$(ls -A "$PROMPTS_DIR" 2>/dev/null)" ] && return
    echo "Summarize this article in 3-5 bullet points." > "$PROMPTS_DIR/summarize.txt"
    echo "Extract the key arguments and counter-arguments from this article." > "$PROMPTS_DIR/arguments.txt"
    echo "What are the main takeaways and action items from this article?" > "$PROMPTS_DIR/takeaways.txt"
    echo "Critique this article. What claims lack evidence? What is the author's bias?" > "$PROMPTS_DIR/critique.txt"
    echo "Explain this article in simple terms, as if to someone unfamiliar with the topic." > "$PROMPTS_DIR/eli5.txt"
}

prompt_url() {
    install_dependencies gum trafilatura glow

    local input
    input=$(gum input --placeholder "Paste a URL to read" --width 80 --char-limit 500) || true
    if [[ "$input" =~ ^https?:// ]]; then
        fetch_article "$input"
    else
        echo "No URL provided."
    fi
}

fetch_article() {
    install_dependencies gum trafilatura glow

    local url="$1"

    # Extract article content as markdown via trafilatura (with spinner)
    local content
    if ! content=$(gum spin --spinner dot --title "Fetching $url..." -- trafilatura --output-format markdown -u "$url" 2>/dev/null); then
        echo "Error: failed to fetch article content from $url" >&2
        return 1
    fi
    if [ -z "$content" ]; then
        echo "Error: no article content found at $url" >&2
        return 1
    fi

    # Extract title from first markdown heading, fallback to URL slug
    local title
    title=$(echo "$content" | grep -m1 '^# ' | sed 's/^# //' || true)
    [ -z "$title" ] && title=$(echo "$url" | sed 's|.*/||; s|[?#].*||')

    # Slugify: lowercase, strip non-alnum, spaces→hyphens, truncate
    local slug
    slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 -]//g' | tr ' ' '-' | sed 's/--*/-/g' | cut -c1-60)
    [ -z "$slug" ] && slug="untitled"

    local date_prefix
    date_prefix=$(date +%y%m%d)
    local filename="${date_prefix}-${slug}.md"
    local filepath="$ARTICLES_DIR/$filename"

    # Remove existing file for same URL (duplicate handling)
    grep -rl "^url: $url$" "$ARTICLES_DIR" 2>/dev/null | xargs rm -f || true

    # Save with URL in frontmatter
    {
        echo "---"
        echo "url: $url"
        echo "---"
        echo ""
        echo "$content"
    } > "$filepath"

    echo "Saved: $filepath"

    # Open for reading; quitting glow exits the app
    glow -p "$filepath"
}

# Strip YAML frontmatter from an article file
strip_frontmatter() {
    awk 'BEGIN{fm=0} /^---$/{fm++; next} fm>=2||fm==0{print}' "$1"
}

# Process an article with a selected prompt via mods
process_article() {
    install_dependencies gum crush

    local filepath="$1"

    init_prompts
    local prompt_files=("$PROMPTS_DIR"/*.txt)
    if [ ${#prompt_files[@]} -eq 0 ]; then
        echo "No prompts found in $PROMPTS_DIR/"
        return
    fi

    # Build display names from filenames (strip path + extension)
    local names=()
    for f in "${prompt_files[@]}"; do
        names+=("$(basename "$f" .txt)")
    done

    local choice
    choice=$(printf '%s\n' "${names[@]}" | gum choose --header "Process article with prompt:") || return

    local prompt
    prompt=$(cat "$PROMPTS_DIR/${choice}.txt")

    strip_frontmatter "$filepath" | crush run "$prompt"
}

browse_history() {
    install_dependencies gum glow fzf

    if [ -z "$(ls -A "$ARTICLES_DIR" 2>/dev/null)" ]; then
        echo "No saved articles yet."
        prompt_url
        return
    fi

    # Prompt: paste URL or browse
    local input
    input=$(gum input --placeholder "Paste a URL, or press Enter to browse history" --width 80 --char-limit 500) || true

    if [[ "$input" =~ ^https?:// ]]; then
        fetch_article "$input"
        return
    fi

    # fzf-based browser: Enter=read, →=process with prompt
    local selected
    selected=$(
        ls -t "$ARTICLES_DIR"/*.md 2>/dev/null |
        fzf --header="Enter: read  →: process with AI  Esc: quit" \
            --expect=right,enter \
            --preview="glow -w 80 {}" \
            --preview-window=right:60%:wrap \
            --delimiter='/' --with-nth=-1 \
            --no-info
    ) || { return; }

    local action
    action=$(echo "$selected" | head -1)
    local filepath
    filepath=$(echo "$selected" | tail -1)

    [ -z "$filepath" ] && return

    if [ "$action" = "right" ]; then
        process_article "$filepath"
        browse_history
    else
        # Quitting glow exits the app
        glow -p "$filepath"
    fi
}

# --- main ---
if [ $# -eq 0 ]; then
    browse_history
else
    fetch_article "$1"
fi
