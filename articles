#!/usr/bin/env bash
# articles — fetch web articles and browse them in the terminal
set -euo pipefail

ARTICLES_DIR="${ARTICLES_DIR:-$HOME/articles}"
mkdir -p "$ARTICLES_DIR"

prompt_url() {
    local input
    input=$(gum input --placeholder "Paste a URL to read" --width 80 --char-limit 500) || true
    if [[ "$input" =~ ^https?:// ]]; then
        fetch_article "$input"
    else
        echo "No URL provided."
    fi
}

fetch_article() {
    local url="$1"

    # Extract article content as markdown via trafilatura (with spinner)
    local content
    content=$(gum spin --spinner dot --title "Fetching $url..." -- trafilatura --output-format markdown -u "$url" 2>/dev/null)
    if [ -z "$content" ]; then
        echo "Error: no article content found at $url" >&2
        exit 1
    fi

    # Extract title from first markdown heading, fallback to URL slug
    local title
    title=$(echo "$content" | grep -m1 '^# ' | sed 's/^# //')
    [ -z "$title" ] && title=$(echo "$url" | sed 's|.*/||; s|[?#].*||')

    # Slugify: lowercase, strip non-alnum, spaces→hyphens, truncate
    local slug
    slug=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 -]//g' | tr ' ' '-' | sed 's/--*/-/g' | cut -c1-60)
    [ -z "$slug" ] && slug="untitled"

    local date_prefix
    date_prefix=$(date +%y%m%d)
    local filename="${date_prefix}-${slug}.md"
    local filepath="$ARTICLES_DIR/$filename"

    # Remove existing file for same URL (duplicate handling)
    grep -rl "^url: $url$" "$ARTICLES_DIR" 2>/dev/null | xargs rm -f

    # Save with URL in frontmatter
    {
        echo "---"
        echo "url: $url"
        echo "---"
        echo ""
        echo "$content"
    } > "$filepath"

    echo "Saved: $filepath"

    # Open for reading
    glow -p "$filepath"
}

browse_history() {
    if [ -z "$(ls -A "$ARTICLES_DIR" 2>/dev/null)" ]; then
        echo "No saved articles yet."
        prompt_url
        return
    fi

    # Prompt: paste URL or browse
    local input
    input=$(gum input --placeholder "Paste a URL, or press Enter to browse history" --width 80 --char-limit 500) || true

    if [[ "$input" =~ ^https?:// ]]; then
        fetch_article "$input"
    else
        glow "$ARTICLES_DIR"
    fi
}

# --- main ---
if [ $# -eq 0 ]; then
    browse_history
else
    fetch_article "$1"
fi
